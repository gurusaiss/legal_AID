# ── Gemini (required for AI chat + RAG embeddings) ──────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase (required for cases DB + RAG vector search) ─────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-only, never expose in client

# ── RAG corpus seeding (one-time operation) ───────────────────────────
# Set any secret value; pass it as X-Seed-Secret header when calling POST /api/seed-corpus
SEED_SECRET=change_me_to_something_random

# ── Optional ──────────────────────────────────────────────────────────
PING_MESSAGE=pong
PORT=3000
