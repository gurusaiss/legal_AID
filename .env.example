# ── Gemini (required for AI chat + RAG embeddings) ───────────────────────────
# Get from: https://aistudio.google.com/app/apikey  (free, no credit card)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Neon PostgreSQL (required for cases DB + RAG vector search) ───────────────
# Get from: https://console.neon.tech → New Project → Connection Details
# Copy the "Connection string" (starts with postgresql://...)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── RAG corpus seeding (one-time operation) ───────────────────────────────────
# Set any random secret; pass it as X-Seed-Secret header when calling POST /api/seed-corpus
SEED_SECRET=change_me_to_something_random

# ── Optional ──────────────────────────────────────────────────────────────────
PING_MESSAGE=pong
PORT=3000
